class ConnectorTracker:
    """Трекер для стабильного отслеживания 4 коннекторов между кадрами"""

    def __init__(self, max_distance=50, history_size=5, smoothing_alpha=0.3):
        self.max_distance = max_distance
        self.smoothing_alpha = smoothing_alpha
        self.history_size = history_size

        self.point_history = {i: deque(maxlen=history_size) for i in range(4)}
        self.last_positions = None
        self.confidence = {i: 1.0 for i in range(4)}

    def get_predicted_position(self, point_idx):
        """Предсказывает следующую позицию на основе истории"""
        history = list(self.point_history[point_idx])
        if len(history) < 2:
            return None

        if len(history) >= 3:
            v1 = np.array(history[-1]) - np.array(history[-2])
            v2 = np.array(history[-2]) - np.array(history[-3])
            avg_velocity = (v1 + v2 * 0.5) / 2
            return np.array(history[-1]) + avg_velocity
        else:
            return np.array(history[-1])

    def match_points(self, detected_points):
        """Сопоставляет детектированные точки с предыдущими позициями"""
        if len(detected_points) != 4:
            return None

        if self.last_positions is None:
            return self._sort_points_initial(detected_points)

        n = 4
        cost_matrix = np.zeros((n, n))

        for i in range(n):
            pred_pos = self.get_predicted_position(i)
            if pred_pos is None:
                pred_pos = self.last_positions[i]

            for j in range(n):
                dist = np.linalg.norm(np.array(detected_points[j]) - pred_pos)
                cost_matrix[i, j] = dist

        assigned = [-1] * n
        used = [False] * n

        pairs = []
        for i in range(n):
            for j in range(n):
                pairs.append((cost_matrix[i, j], i, j))
        pairs.sort()

        for dist, i, j in pairs:
            if assigned[i] == -1 and not used[j]:
                if dist < self.max_distance:
                    assigned[i] = j
                    used[j] = True

        if -1 in assigned:
            result = []
            for i in range(4):
                if assigned[i] != -1:
                    pos = detected_points[assigned[i]]
                    self.confidence[i] = min(1.0, self.confidence[i] + 0.1)
                else:
                    pos = self.get_predicted_position(i)
                    if pos is None:
                        pos = self.last_positions[i] if self.last_positions else detected_points[i]
                    self.confidence[i] = max(0.0, self.confidence[i] - 0.3)
                result.append(pos)
            return result

        result = []
        for i in range(4):
            pos = detected_points[assigned[i]]
            self.confidence[i] = min(1.0, self.confidence[i] + 0.05)
            result.append(pos)

        return result

    def _sort_points_initial(self, points):
        """Начальная сортировка 4 точек: TL, TR, BL, BR"""
        points_sorted_y = sorted(points, key=lambda k: k[1])
        top_two = sorted(points_sorted_y[:2], key=lambda k: k[0])
        bottom_two = sorted(points_sorted_y[2:], key=lambda k: k[0])
        return top_two + bottom_two

    def update(self, ordered_points):
        """Обновляет историю позиций"""
        if ordered_points is None or len(ordered_points) != 4:
            return

        for i, pos in enumerate(ordered_points):
            self.point_history[i].append(np.array(pos))

        self.last_positions = [np.array(p) for p in ordered_points]

    def get_smoothed_positions(self):
        """Возвращает сглаженные позиции"""
        if self.last_positions is None:
            return None

        smoothed = []
        for i in range(4):
            history = list(self.point_history[i])
            if len(history) == 0:
                smoothed.append(self.last_positions[i])
                continue

            if len(history) >= 3:
                weights = [0.5, 0.3, 0.2]
                weighted_pos = np.zeros(2)
                for j, w in enumerate(weights):
                    if len(history) > j:
                        weighted_pos += w * history[-(j + 1)]
                smoothed.append(weighted_pos)
            else:
                pos = np.array(history[-1])
                if len(history) > 1:
                    prev = np.array(history[-2])
                    pos = prev * (1 - self.smoothing_alpha) + pos * self.smoothing_alpha
                smoothed.append(pos)

        return smoothed


class FastDroneDetector:
    # --- Параметры желтых коннекторов (Дрон) ---
    H_MIN = 13
    H_MAX = 35
    S_MIN = 113
    S_MAX = 163
    V_MIN = 151
    V_MAX = 255
    YELLOW_AREA_MIN = 6
    YELLOW_AREA_MAX = 494
    YELLOW_KERNEL = 2
    YELLOW_DILATE = 6
    YELLOW_ERODE = 0

    # --- Параметры ArUco (Дно стенда - Референс) ---
    ARUCO_DICT = aruco.DICT_4X4_100
    REF_MARKER_IDS = [1, 2]

    # --- Настройки фильтрации ---
    SMOOTHING_FACTOR = 0.3
    PITCH_SENSITIVITY = 0.8
    MAX_POINT_JUMP = 50

    def __init__(self):
        # === НАСТРОЙКИ КАМЕРЫ ===
        self.CAMERA_ANGLE = 40
        self.CAMERA_ELEVATION = 43
        self.USE_DIAGONAL_MODE = True

        # Zero offset
        self.zero_roll = 0.0
        self.zero_pitch = 0.0
        self.roll_zero_set = False
        self.pitch_zero_set = False

        self.ref_connectors = None
        self.ref_marker_centers = None
        self.calibrated = False

        self.paused = False
        self.last_roll = 0.0
        self.last_pitch = 0.0
        self.last_update_time = 0

        # === ИНИЦИАЛИЗАЦИЯ ТРЕКЕРА ===
        self.connector_tracker = ConnectorTracker(
            max_distance=self.MAX_POINT_JUMP,
            history_size=5,
            smoothing_alpha=self.SMOOTHING_FACTOR
        )

        # === ДЛЯ ЗАПИСИ В EXCEL ===
        self.recording = False
        self.recording_start_time = 0
        self.RECORD_DURATION = 2.0
        self.recorded_data = []
        self.measurement_count = 0
        self.excel_filename = "drone_measurements.xlsx"
        self.last_recording_end = 0
        self.COOLDOWN = 0.5

        if EXCEL_AVAILABLE and not os.path.exists(self.excel_filename):
            self._create_excel_file()

        # Инициализация ArUco
        self.aruco_dict = aruco.getPredefinedDictionary(self.ARUCO_DICT)
        self.aruco_params = aruco.DetectorParameters()
        self.aruco_params.cornerRefinementMethod = aruco.CORNER_REFINE_SUBPIX
        self.aruco_params.adaptiveThreshWinSizeMin = 3
        self.aruco_params.adaptiveThreshWinSizeMax = 23
        self.aruco_params.adaptiveThreshWinSizeStep = 10
        self.aruco_params.polygonalApproxAccuracyRate = 0.03
        self.aruco_params.minCornerDistanceRate = 0.05
        self.aruco_params.minDistanceToBorder = 3
        self.aruco_detector = aruco.ArucoDetector(self.aruco_dict, self.aruco_params)

    @staticmethod
    def normalize_angle(angle):
        while angle > 180:
            angle -= 360
        while angle < -180:
            angle += 360
        return angle

    def _create_excel_file(self):
        """Создает Excel файл с заголовками"""
        try:
            df = pd.DataFrame(columns=['№ измерения', 'Тангаж |Pitch|, °', 'Крен |Roll|, °', 'Pitch (знак)', 'Roll (знак)', 'Время'])
            df.to_excel(self.excel_filename, index=False, sheet_name='Измерения')
            print(f"✅ Создан файл: {self.excel_filename}")
        except Exception as e:
            print(f"❌ Ошибка создания Excel: {e}")

    def trigger_recording(self):
        """Запускает запись на фиксированное время"""
        if time.time() - self.last_recording_end < self.COOLDOWN:
            print("⏳ Подождите немного перед следующей записью")
            return

        if self.recording:
            return

        self.recording = True
        self.recording_start_time = time.time()
        self.recorded_data = []
        print(f"\n📝 ЗАПИСЬ: {self.RECORD_DURATION} сек...")

    def check_recording_complete(self):
        """Проверяет завершение записи и сохраняет данные"""
        if not self.recording:
            return False

        elapsed = time.time() - self.recording_start_time

        if elapsed >= self.RECORD_DURATION:
            self._save_recorded_data()
            return True

        return False

    def _save_recorded_data(self):
        """Сохраняет накопленные данные в Excel"""
        self.recording = False
        self.last_recording_end = time.time()

        # === ИСПРАВЛЕНО: было self.recorded_ вместо self.recorded_data ===
        if not self.recorded_data:
            print("⚠️  Нет данных для сохранения")
            return

        pitches = [d[0] for d in self.recorded_data]
        rolls = [d[1] for d in self.recorded_data]

        avg_pitch = np.mean(pitches)
        avg_roll = np.mean(rolls)
        std_pitch = np.std(pitches)
        std_roll = np.std(rolls)

        self.measurement_count += 1

        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        new_data = {
            '№ измерения': self.measurement_count,
            'Тангаж |Pitch|, °': round(abs(avg_pitch), 2),
            'Крен |Roll|, °': round(abs(avg_roll), 2),
            'Pitch (знак)': round(avg_pitch, 2),
            'Roll (знак)': round(avg_roll, 2),
            'Время': timestamp
        }

        try:
            if os.path.exists(self.excel_filename):
                df = pd.read_excel(self.excel_filename, sheet_name='Измерения')
            else:
                df = pd.DataFrame(columns=['№ измерения', 'Тангаж |Pitch|, °', 'Крен |Roll|, °', 'Pitch (знак)', 'Roll (знак)', 'Время'])

            new_row = pd.DataFrame([new_data])
            df = pd.concat([df, new_row], ignore_index=True)

            df.to_excel(self.excel_filename, index=False, sheet_name='Измерения')

            print(f"\n💾 ИЗМЕРЕНИЕ #{self.measurement_count} СОХРАНЕНО:")
            print(f"   PITCH: {avg_pitch:+6.2f}° (|{abs(avg_pitch):.2f}|°) ± {std_pitch:.2f}°")
            print(f"   ROLL:  {avg_roll:+6.2f}° (|{abs(avg_roll):.2f}|°) ± {std_roll:.2f}°")
            print(f"   Отсчетов: {len(self.recorded_data)} | Файл: {self.excel_filename}")

        except Exception as e:
            print(f"❌ Ошибка записи в Excel: {e}")

    def add_data_point(self, pitch, roll):
        """Добавляет точку данных при записи"""
        if self.recording:
            self.recorded_data.append((pitch, roll))

    def detect_aruco_reference(self, frame):
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        corners, ids, rejected = self.aruco_detector.detectMarkers(gray)

        marker_centers = []
        if ids is not None and len(ids) > 0:
            aruco.drawDetectedMarkers(frame, corners, ids, (0, 255, 0))
            for i, marker_id in enumerate(ids.flatten()):
                if marker_id in self.REF_MARKER_IDS:
                    center = corners[i][0].mean(axis=0).astype(int)
                    marker_centers.append({'id': marker_id, 'center': tuple(center)})
                    cv2.circle(frame, center, 5, (0, 255, 0), -1)

        return marker_centers

    def detect_yellow_connectors(self, frame):
        hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)
        lower = np.array([self.H_MIN, self.S_MIN, self.V_MIN])
        upper = np.array([self.H_MAX, self.S_MAX, self.V_MAX])
        mask = cv2.inRange(hsv, lower, upper)

        kernel = np.ones((self.YELLOW_KERNEL, self.YELLOW_KERNEL), np.uint8)
        mask = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, kernel)
        mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN, kernel)
        mask = cv2.dilate(mask, kernel, iterations=self.YELLOW_DILATE)
        mask = cv2.erode(mask, kernel, iterations=self.YELLOW_ERODE)

        contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
        connectors = []

        for cnt in contours:
            area = cv2.contourArea(cnt)
            if self.YELLOW_AREA_MIN < area < self.YELLOW_AREA_MAX:
                M = cv2.moments(cnt)
                if M["m00"] != 0:
                    cX = int(M["m10"] / M["m00"])
                    cY = int(M["m01"] / M["m00"])
                    connectors.append([cX, cY])

        if len(connectors) == 4:
            ordered = self.connector_tracker.match_points(connectors)
            if ordered is not None:
                self.connector_tracker.update(ordered)
                connectors = ordered
            else:
                connectors = self._sort_points_initial(connectors)
                self.connector_tracker.update(connectors)
        elif len(connectors) > 0:
            smoothed = self.connector_tracker.get_smoothed_positions()
            if smoothed is not None:
                connectors = smoothed

        return connectors, mask

    def _sort_points_initial(self, points):
        """Начальная сортировка: TL, TR, BL, BR"""
        points_sorted_y = sorted(points, key=lambda k: k[1])
        top_two = sorted(points_sorted_y[:2], key=lambda k: k[0])
        bottom_two = sorted(points_sorted_y[2:], key=lambda k: k[0])
        return top_two + bottom_two

    def compensate_camera_shift(self, connectors, current_markers):
        if not self.calibrated or self.ref_marker_centers is None or len(connectors) == 0:
            return connectors

        ref_ids = {m['id']: m['center'] for m in self.ref_marker_centers}
        curr_ids = {m['id']: m['center'] for m in current_markers}
        common_ids = set(ref_ids.keys()) & set(curr_ids.keys())

        if len(common_ids) < 1:
            return connectors

        dx_sum, dy_sum, count = 0, 0, 0
        for mid in common_ids:
            dx = ref_ids[mid][0] - curr_ids[mid][0]
            dy = ref_ids[mid][1] - curr_ids[mid][1]
            dx_sum += dx
            dy_sum += dy
            count += 1

        avg_dx = dx_sum / count
        avg_dy = dy_sum / count

        compensated = []
        for conn in connectors:
            compensated.append([int(conn[0] + avg_dx), int(conn[1] + avg_dy)])

        return compensated

    def calculate_angles(self, connectors):
        """
        УЛУЧШЕННЫЙ расчёт углов с компенсацией комбинированных отклонений
        """
        if len(connectors) < 4:
            return 0.0, 0.0, False, False

        tl, tr, bl, br = connectors

        # === Шаг 1: Вычисляем центр дрона ===
        center = np.array([
            (tl[0] + tr[0] + bl[0] + br[0]) / 4,
            (tl[1] + tr[1] + bl[1] + br[1]) / 4
        ])

        # === Шаг 2: Поворот системы координат для диагональной камеры ===
        if self.USE_DIAGONAL_MODE and abs(self.CAMERA_ANGLE) > 10:
            angle_rad = math.radians(-self.CAMERA_ANGLE)
            cos_a, sin_a = math.cos(angle_rad), math.sin(angle_rad)

            points = [tl, tr, bl, br]
            rotated_points = []
            for p in points:
                v = np.array(p) - center
                v_rot = np.array([
                    v[0] * cos_a - v[1] * sin_a,
                    v[0] * sin_a + v[1] * cos_a
                ])
                rotated_points.append((center + v_rot).astype(int))

            tl, tr, bl, br = rotated_points

        # === Шаг 3: Расчёт ROLL (независимый от Pitch) ===
        left_y = (tl[1] + bl[1]) / 2
        right_y = (tr[1] + br[1]) / 2
        left_x = (tl[0] + bl[0]) / 2
        right_x = (tr[0] + br[0]) / 2

        dx_roll = right_x - left_x
        dy_roll = right_y - left_y

        roll_base = np.sqrt(dx_roll**2 + dy_roll**2)
        if roll_base < 10:
            roll_base = 10

        raw_roll = self.normalize_angle(math.degrees(math.atan2(dy_roll, dx_roll)) - 90)

        # === Шаг 4: Расчёт PITCH (с компенсацией Roll) ===
        roll_rad = math.radians(raw_roll)

        def compensate_roll(point, center, roll_rad):
            v = np.array(point) - center
            v_comp = np.array([
                v[0] * math.cos(-roll_rad) - v[1] * math.sin(-roll_rad),
                v[0] * math.sin(-roll_rad) + v[1] * math.cos(-roll_rad)
            ])
            return center + v_comp

        tl_comp = compensate_roll(tl, center, roll_rad)
        tr_comp = compensate_roll(tr, center, roll_rad)
        bl_comp = compensate_roll(bl, center, roll_rad)
        br_comp = compensate_roll(br, center, roll_rad)

        front_y = (tl_comp[1] + tr_comp[1]) / 2
        back_y = (bl_comp[1] + br_comp[1]) / 2
        front_x = (tl_comp[0] + tr_comp[0]) / 2
        back_x = (bl_comp[0] + br_comp[0]) / 2

        vertical_diff = front_y - back_y
        horizontal_dist = np.sqrt((front_x - back_x)**2 + (front_y - back_y)**2)

        if horizontal_dist < 10:
            horizontal_dist = 10

        base_pitch = math.degrees(math.atan2(vertical_diff, horizontal_dist))

        # === Шаг 5: Асимметричная чувствительность ===
        elevation_factor = 1.0 + abs(self.CAMERA_ELEVATION) / 30.0

        if base_pitch > 0:
            raw_pitch = base_pitch * self.PITCH_SENSITIVITY * elevation_factor * 0.7
        else:
            raw_pitch = base_pitch * self.PITCH_SENSITIVITY * elevation_factor * 1.4

        # === Шаг 6: Асимметричная чувствительность Roll ===
        if raw_roll > 0:
            raw_roll = raw_roll * 1.4

        raw_pitch = self.normalize_angle(raw_pitch)
        raw_roll = self.normalize_angle(raw_roll)

        return raw_roll, raw_pitch, True, True

    def set_calibration_zero(self, connectors, markers):
        self.ref_connectors = [list(p) for p in connectors]
        self.ref_marker_centers = markers

        raw_roll, raw_pitch, _, _ = self.calculate_angles(connectors)
        self.zero_roll = raw_roll
        self.zero_pitch = raw_pitch

        self.calibrated = True
        self.roll_zero_set = True
        self.pitch_zero_set = True

        print(f"✅ КАЛИБРОВКА: ROLL_ZERO={self.zero_roll:.2f}°, PITCH_ZERO={self.zero_pitch:.2f}°")

    def draw_debug_info(self, frame, connectors, ref_markers, roll, pitch, has_roll, has_pitch):
        h, w = frame.shape[:2]

        for i, conn in enumerate(connectors):
            if hasattr(self, 'connector_tracker'):
                conf = self.connector_tracker.confidence.get(i, 1.0)
                if conf > 0.7:
                    color = (0, 255, 0)
                elif conf > 0.4:
                    color = (0, 255, 255)
                else:
                    color = (0, 0, 255)
            else:
                color = (0, 255, 0) if self.calibrated else (0, 255, 255)

            cv2.circle(frame, (int(conn[0]), int(conn[1])), 10, color, 2)
            cv2.putText(frame, f"{i}", (int(conn[0]) + 12, int(conn[1]) - 5),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.6, color, 2)

        if len(connectors) == 4:
            pts = np.array(connectors, np.int32).reshape((-1, 1, 2))
            cv2.polylines(frame, [pts], True, (0, 255, 255), 2)

            if self.USE_DIAGONAL_MODE:
                center = np.mean(connectors, axis=0).astype(int)
                axis_length = 50
                angle_rad = math.radians(self.CAMERA_ANGLE)

                x_end = (int(center[0] + axis_length * math.cos(angle_rad)),
                         int(center[1] + axis_length * math.sin(angle_rad)))
                cv2.arrowedLine(frame, tuple(center), tuple(x_end), (0, 0, 255), 2, tipLength=0.2)
                cv2.putText(frame, "X", (x_end[0] + 5, x_end[1]),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 0, 255), 2)

                y_end = (int(center[0] - axis_length * math.sin(angle_rad)),
                         int(center[1] + axis_length * math.cos(angle_rad)))
                cv2.arrowedLine(frame, tuple(center), tuple(y_end), (0, 255, 0), 2, tipLength=0.2)
                cv2.putText(frame, "Y", (y_end[0] + 5, y_end[1]),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2)

                cv2.circle(frame, tuple(center), 6, (255, 255, 255), -1)

        y_off = 40
        cv2.putText(frame, f"CAM: {self.CAMERA_ANGLE}°/{self.CAMERA_ELEVATION}°",
                    (10, y_off), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (200, 200, 200), 1)
        y_off += 25

        status_color = (0, 255, 0) if self.calibrated else (0, 0, 255)
        cv2.putText(frame, f"STATUS: {'CALIBRATED' if self.calibrated else 'NEED CALIBRATION'}",
                    (10, y_off), cv2.FONT_HERSHEY_SIMPLEX, 0.7, status_color, 2)
        y_off += 35

        if hasattr(self, 'connector_tracker') and self.connector_tracker.last_positions is not None:
            avg_conf = np.mean(list(self.connector_tracker.confidence.values()))
            cv2.putText(frame, f"TRACK CONF: {avg_conf:.1%}", (10, y_off),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 255) if avg_conf > 0.7 else (0, 0, 255), 2)
            y_off += 25

        cv2.putText(frame, f"Connectors: {len(connectors)}/4", (10, y_off),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 0), 2)
        y_off += 35

        pitch_color = (0, 255, 255) if has_pitch else (100, 100, 100)
        roll_color = (0, 255, 0) if has_roll else (100, 100, 100)
        cv2.putText(frame, f"PITCH: {pitch:+6.2f}°", (10, y_off),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.8, pitch_color, 2)
        y_off += 35
        cv2.putText(frame, f"ROLL:  {roll:+6.2f}°", (10, y_off),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.8, roll_color, 2)

        if self.paused:
            cv2.putText(frame, "PAUSED", (w // 2 - 80, 50),
                        cv2.FONT_HERSHEY_SIMPLEX, 1.5, (0, 0, 255), 3)

        return frame

    def process_frame(self, frame):
        current_time = time.time()

        ref_markers = self.detect_aruco_reference(frame)
        connectors, mask_yellow = self.detect_yellow_connectors(frame)

        if self.calibrated:
            connectors = self.compensate_camera_shift(connectors, ref_markers)

        raw_roll, raw_pitch, has_roll, has_pitch = 0, 0, False, False

        if len(connectors) == 4:
            if hasattr(self, 'connector_tracker'):
                avg_conf = np.mean(list(self.connector_tracker.confidence.values()))
                if avg_conf > 0.3:
                    raw_roll, raw_pitch, has_roll, has_pitch = self.calculate_angles(connectors)

            if has_roll and self.roll_zero_set:
                raw_roll = self.normalize_angle(raw_roll - self.zero_roll)
            if has_pitch and self.pitch_zero_set:
                raw_pitch = self.normalize_angle(raw_pitch - self.zero_pitch)

            if has_roll:
                self.last_roll = self.last_roll * (1 - self.SMOOTHING_FACTOR) + raw_roll * self.SMOOTHING_FACTOR
            if has_pitch:
                self.last_pitch = self.last_pitch * (1 - self.SMOOTHING_FACTOR) + raw_pitch * self.SMOOTHING_FACTOR

            if self.recording and has_roll and has_pitch:
                self.add_data_point(self.last_pitch, self.last_roll)

            if self.recording:
                self.check_recording_complete()

        roll = self.normalize_angle(self.last_roll)
        pitch = self.normalize_angle(self.last_pitch)

        frame = self.draw_debug_info(frame, connectors, ref_markers, roll, pitch, has_roll, has_pitch)

        if self.recording:
            elapsed = time.time() - self.recording_start_time
            progress = min(1.0, elapsed / self.RECORD_DURATION)

            bar_len = 20
            filled = int(bar_len * progress)
            bar = "█" * filled + "░" * (bar_len - filled)

            cv2.putText(frame, f"REC [{bar}] {elapsed:.1f}s",
                       (10, frame.shape[0] - 50),
                       cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 0, 255), 2)
            if int(elapsed * 4) % 2 == 0:
                cv2.circle(frame, (35, frame.shape[0] - 60), 8, (0, 0, 255), -1)

        if (has_roll or has_pitch) and (current_time - self.last_update_time > 0.5):
            conf_info = ""
            if hasattr(self, 'connector_tracker'):
                avg_conf = np.mean(list(self.connector_tracker.confidence.values()))
                conf_info = f" | Conf: {avg_conf:.0%}"
            print(f"\n📊 [{time.strftime('%H:%M:%S')}] R:{roll:+6.2f}° P:{pitch:+6.2f}°{conf_info}")
            self.last_update_time = current_time

        return frame, mask_yellow, None, roll, pitch, has_roll, has_pitch


def run(source=0, is_video=False):
    detector = FastDroneDetector()

    if is_video:
        cap = cv2.VideoCapture(source)
        print(f"📹 Открыт видеофайл: {source}")
    else:
        cap = cv2.VideoCapture(source)
        print(f"📹 Открыта камера: {source}")

    if not cap.isOpened():
        print("❌ Не удалось открыть источник видео")
        return

    if not is_video:
        cap.set(cv2.CAP_PROP_FRAME_WIDTH, 1280)
        cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 720)
        cap.set(cv2.CAP_PROP_AUTO_EXPOSURE, 0.25)
        cap.set(cv2.CAP_PROP_EXPOSURE, -6)

    fps = cap.get(cv2.CAP_PROP_FPS)
    width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    if fps == 0:
        fps = 30

    print("=" * 70)
    print("🚀 DRONE DETECTOR (With Stable Tracking + Excel Export)")
    print("=" * 70)
    print(f"📐 {width}x{height} | 🎬 {fps:.1f} FPS" + (f" | 📁 {total_frames} frames" if is_video else ""))
    print(f"📷 Camera: Angle={detector.CAMERA_ANGLE}°, Elev={detector.CAMERA_ELEVATION}°")
    print("=" * 70)
    print("УПРАВЛЕНИЕ:")
    print("  C - КАЛИБРОВКА (дрон в 0°)")
    print("  R - Сброс калибровки")
    print("  W - ЗАПИСЬ 2 сек в Excel (одно нажатие)")
    print("  SPACE - Пауза | S - Сохранить кадр | Q - Выход")
    print("=" * 70)
    if EXCEL_AVAILABLE:
        print(f"📊 Excel файл: {detector.excel_filename}")
    print("=" * 70)
    print("💡 Трекинг включен: точки не будут прыгать между кадрами")
    print("=" * 70)

    cv2.namedWindow('Result')
    cv2.namedWindow('Yellow Mask')
    if is_video:
        cv2.namedWindow('Controls')
        cv2.createTrackbar('Frame', 'Controls', 0, max(1, total_frames), lambda x: None)

    frame_count = 0
    start_time = time.time()
    last_saved_frame = -1

    while True:
        if detector.paused and is_video:
            pos = cv2.getTrackbarPos('Frame', 'Controls')
            cap.set(cv2.CAP_PROP_POS_FRAMES, pos)
            frame_count = pos

        ret, frame = cap.read()
        if not ret:
            if is_video:
                print("🏁 Конец видео, зацикливание...")
                cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
                frame_count = 0
                continue
            else:
                print("❌ Ошибка чтения кадра")
                break

        if is_video:
            current_pos = int(cap.get(cv2.CAP_PROP_POS_FRAMES))
            cv2.setTrackbarPos('Frame', 'Controls', current_pos)

        if not detector.paused:
            res, mask, _, roll, pitch, hr, hp = detector.process_frame(frame)
            cv2.imshow('Result', res)
            cv2.imshow('Yellow Mask', cv2.resize(mask, (width // 2, height // 2)))
            frame_count += 1

        key = cv2.waitKey(1) & 0xFF
        if key == ord('q'):
            break
        elif key == 32:
            detector.paused = not detector.paused
            print("⏸️ PAUSE" if detector.paused else "▶️ PLAY")
        elif key == ord('c'):
            cons, _ = detector.detect_yellow_connectors(frame)
            marks = detector.detect_aruco_reference(frame)
            if len(cons) == 4 and len(marks) >= 1:
                detector.set_calibration_zero(cons, marks)
            else:
                print(f"⚠️  Нужно 4 коннектора и 1+ маркер! {len(cons)} конн, {len(marks)} марк")
        elif key == ord('r'):
            detector.calibrated = False
            detector.ref_connectors = None
            detector.ref_marker_centers = None
            detector.zero_roll = 0.0
            detector.zero_pitch = 0.0
            detector.roll_zero_set = False
            detector.pitch_zero_set = False
            if hasattr(detector, 'connector_tracker'):
                detector.connector_tracker.last_positions = None
                for i in range(4):
                    detector.connector_tracker.point_history[i].clear()
                    detector.connector_tracker.confidence[i] = 1.0
            print("🔄 Калибровка сброшена")
        elif key == ord('w'):
            detector.trigger_recording()
        elif key == ord('s'):
            if frame_count != last_saved_frame:
                filename = f'debug_frame_{frame_count:05d}.png'
                cv2.imwrite(filename, res)
                mask_filename = f'debug_mask_{frame_count:05d}.png'
                cv2.imwrite(mask_filename, mask)
                print(f"💾 Saved: {filename}, {mask_filename}")
                last_saved_frame = frame_count

    cap.release()
    cv2.destroyAllWindows()

    elapsed = time.time() - start_time
    fps_actual = frame_count / elapsed if elapsed > 0 else 0
    print(f"\n{'=' * 70}")
    print(f"Обработано: {frame_count} кадров | {elapsed:.2f} сек | FPS: {fps_actual:.1f}")
    print(f"{'=' * 70}")


if __name__ == "__main__":
    if len(sys.argv) > 1:
        run(source=sys.argv[1], is_video=True)
    else:
        run(source=0, is_video=False)
